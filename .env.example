# ── Daytona ───────────────────────────────────────────────────────────────────
# Required: Your Daytona API key (from https://app.daytona.io/settings)
DAYTONA_API_KEY=your_daytona_api_key_here

# Optional: Daytona server URL (default points to Daytona Cloud)
DAYTONA_API_URL=https://app.daytona.io/api

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Required: Anthropic API key for the blue team Claude agents
TENSORIX_API_KEY=example_tensorix_api_key_here

# ── GitHub ────────────────────────────────────────────────────────────────────
# Required: Personal access token with repo scope
# Create at: https://github.com/settings/tokens/new?scopes=repo
GITHUB_TOKEN=your_github_pat_here

# Required: Target GitHub repository in owner/name format
# Blue team agents will open PRs against this repo
GITHUB_REPO=your-org/your-target-repo

# Required: Local filesystem path to the target repository checkout
# Used by blue team agents to read source files when crafting patches
TARGET_REPO_PATH=/path/to/local/checkout/of/target/repo

# ── Docker images ─────────────────────────────────────────────────────────────
# Docker image for the DVWA target sandbox
# Default: vulnerables/web-dvwa:latest
TARGET_IMAGE=vulnerables/web-dvwa:latest

# Docker image for red team attack sandboxes
# Build with: docker build -f sandbox-images/red.Dockerfile -t openclaw/red:latest .
RED_IMAGE=openclaw/red:latest

# ── Orchestrator tuning ───────────────────────────────────────────────────────
# Maximum recursion depth for exploit fan-out (0 = no recursion)
MAX_DEPTH=3

# Maximum number of concurrent exploit sandboxes
MAX_PARALLEL=10

# Maximum number of concurrent exploit sandboxes
MAX_PARALLEL=10
