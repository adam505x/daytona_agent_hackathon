# ── Daytona ───────────────────────────────────────────────────────────────────
# Required: Daytona API key — stored in Jentic Mini vault in production,
# injected here for local/standalone use.
DAYTONA_API_KEY=your_daytona_api_key_here

# Optional: Daytona server URL
DAYTONA_API_URL=https://app.daytona.io/api

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Required: Anthropic API key for blue team Claude agents
# Store in Jentic Mini vault in production (never commit this file with real keys).
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Override the blue team model (default: claude-sonnet-4-6)
BLUE_TEAM_MODEL=claude-sonnet-4-6

# ── GitHub ────────────────────────────────────────────────────────────────────
# Required: GitHub PAT with repo scope — store in Jentic Mini vault in production
# Create at: https://github.com/settings/tokens/new?scopes=repo
GITHUB_TOKEN=your_github_pat_here

# Required: Repository where blue team opens PRs (owner/name format)
GITHUB_REPO=adam505x/DVWA_Daytona_Hackathon

# Required: Local path to the repo the blue team reads source files from
TARGET_REPO_PATH=.

# ── Jentic Mini ───────────────────────────────────────────────────────────────
# Optional: Fernet encryption key for Jentic Mini's credential vault.
# Auto-generated on first start if not set. Set explicitly to make vault portable.
JENTIC_VAULT_KEY=

# Jentic Mini toolkit key — generated in Jentic Mini UI after adding credentials.
# OpenClaw uses this to route API calls through Jentic Mini.
JENTIC_TOOLKIT_KEY=tk_your_toolkit_key_here

# ── Docker images ─────────────────────────────────────────────────────────────
TARGET_IMAGE=openclaw/target:latest
RED_IMAGE=openclaw/red:latest

# ── Orchestrator tuning ───────────────────────────────────────────────────────
MAX_DEPTH=3
MAX_PARALLEL=8
SNAPSHOT_NAME=openclaw-target-clean
